<Window x:Class="OllamaForVisualStudio.AttachFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vs="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
        Title="Adjuntar Archivos" 
        Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Selecciona archivos del proyecto:" 
                   FontSize="14"
                   Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"
                   Margin="0,0,0,12"/>

        <ListBox Grid.Row="1" 
                 x:Name="FileListBox"
                 SelectionMode="Multiple"
                 Background="{DynamicResource {x:Static vs:EnvironmentColors.ComboBoxBackgroundBrushKey}}"
                 Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"
                 BorderBrush="{DynamicResource {x:Static vs:EnvironmentColors.ComboBoxBorderBrushKey}}"/>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancelar" 
                    Width="80" Height="28"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Adjuntar" 
                    Width="80" Height="28"
                    Background="#0E639C"
                    Foreground="White"
                    Click="Attach_Click"/>
        </StackPanel>
    </Grid>
</Window>